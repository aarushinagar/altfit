// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── USERS ──────────────────────────────────────────────────────
// Row Level Security: Users can only access their own records
model User {
  id           BigInt   @id
  email        String   @unique
  name         String?
  avatar       String?  // Supabase Storage URL or Google picture URL
  passwordHash String?  // null for Google OAuth users
  provider     String   @default("email") // "email" | "google"
  googleId     String?  @unique

  // Onboarding data
  styleProfiles String[] @default([])
  styleIssues   String[] @default([])
  onboarded     Boolean  @default(false)

  // ── Plan & Location ───────────────────────────────────────────
  plan               String    @default("free")  // "free" | "pro"
  wardrobeItemCount  Int       @default(0)
  timezone           String?                     // IANA e.g. "Asia/Kolkata"
  locationLat        Float?
  locationLon        Float?
  locationCity       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  wardrobeItems   WardrobeItem[]
  outfits         Outfit[]
  subscription    Subscription?
  sessions        Session[]
  dailyCurations  DailyCuration[]
  outfitHistories OutfitHistory[]
  styleProfile    UserStyleProfile?
  savedOutfits    SavedOutfit[]
  emailLogs       EmailLog[]

  // Email marketing preferences
  emailOptOut   Boolean  @default(false)    // true = never send marketing emails
  unsubToken    String?  @unique            // random token for one-click unsub link

  @@index([email])
  @@index([googleId])
}

// ── SESSIONS (for JWT refresh tokens) ──────────────────────────
// Row Level Security: Users can only access their own sessions
model Session {
  id        BigInt   @id
  userId    BigInt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique // hashed refresh token
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ── WARDROBE ITEMS ─────────────────────────────────────────────
// Row Level Security: Users can only access their own items
model WardrobeItem {
  id     BigInt @id
  userId BigInt
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core
  name     String
  category String // top | bottom | dress | outerwear | footwear | bag | accessory | outfit

  // Supabase Storage
  imageUrl    String?  // full public CDN URL; null/empty = no photo yet (shows re-upload UI)
  storagePath String?  // e.g. "users/user_id/item_id.webp"; null = no storage object yet

  // AI metadata
  colors     String[] @default([])
  colorNames String[] @default([])
  pattern    String?
  fabric     String?
  fit        String?
  formality  Int      @default(5) // 1-10
  season     String[] @default([])
  occasion   String[] @default([])
  stylistNote String?
  tags       String[] @default([])

  // ── AI Enhanced Metadata ──────────────────────────────────────
  subcategory        String?               // e.g., "t-shirt", "blazer", "chinos"
  primaryColorName   String?               // promoted from colorNames[0] pattern
  primaryColorHex    String?               // hex string e.g. "#4A3B2A"
  secondaryColorName String?
  secondaryColorHex  String?
  colorPattern       String?               // solid|striped|plaid|floral|graphic|animal_print|tie_dye|colorblock|other
  fitType            String?               // slim|regular|relaxed|oversized|tailored|cropped|unknown
  length             String?               // short|midi|long|cropped
  neckline           String?               // crew|v-neck|collared|etc — nullable
  material           String?               // replaces fabric semantically; keep fabric for compat
  texture            String?               // smooth|ribbed|woven|fuzzy|sheer|matte|glossy
  weight             String?               // lightweight|midweight|heavyweight|unknown
  formalityLabel     String?               // casual|smart_casual|business_casual|formal|athletic|loungewear

  // ── Weather/Season Suitability ────────────────────────────────
  suitableTempMinC   Int?
  suitableTempMaxC   Int?
  weatherTags        String[]  @default([]) // sunny|cloudy|light_rain|windy|snow
  styleAesthetic     String[]  @default([]) // streetwear|minimalist|bohemian|preppy|workwear|athleisure|classic
  brand              String?

  // ── LLM Audit Trail ───────────────────────────────────────────
  parseConfidence    Float?
  parseModel         String?
  parseNotes         String?               // what the LLM observed
  displayHint        String?               // e.g. "Focus on the blue t-shirt in this photo"
  needsReview        Boolean  @default(false)
  isActive           Boolean  @default(true)

  // Usage
  wearCount  Int       @default(0)
  lastWornAt DateTime?

  // User annotations
  userRating Int?    // 1–5, optional item rating
  userNotes  String? // personal notes about this piece

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outfitItems OutfitItem[]

  @@index([userId])
  @@index([category])
  @@index([userId, isActive])
}

// ── OUTFITS ────────────────────────────────────────────────────
// Row Level Security: Users can only access their own outfits
model Outfit {
  id     BigInt @id
  userId BigInt
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  occasion       String?
  reasoning      String?
  colorStory     String?
  scoreBalance   Int?
  scoreFormality Int?
  scoreColor     Int?
  scoreNovelty   Int?

  worn   Boolean   @default(false)
  wornAt DateTime?

  createdAt DateTime @default(now())

  items OutfitItem[]

  @@index([userId])
  @@index([createdAt])
}

// ── OUTFIT ITEMS ───────────────────────────────────────────────
// Row Level Security: Enforced via Outfit relationship
model OutfitItem {
  id             BigInt       @id
  outfitId       BigInt
  outfit         Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  wardrobeItemId BigInt
  wardrobeItem   WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)
  role           String? // base | layer | accent | statement

  @@index([outfitId])
  @@index([wardrobeItemId])
}

// ── SUBSCRIPTIONS ──────────────────────────────────────────────
// Row Level Security: Users can only access their own subscriptions
model Subscription {
  id     BigInt @id
  userId BigInt @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   String // "monthly" | "yearly"
  status String // "active" | "cancelled" | "expired"

  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?

  amount   Int    // paise
  currency String @default("INR")

  startedAt   DateTime  @default(now())
  expiresAt   DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ── DAILY CURATIONS ────────────────────────────────────────────
// One record per (userId, localDate, userTimezone) — unique constraint enforces once-per-day
model DailyCuration {
  id              BigInt   @id
  userId          BigInt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Timezone-aware date key (NOT UTC date)
  localDate       String   // "YYYY-MM-DD" in user's local timezone
  userTimezone    String   // IANA, e.g. "Asia/Kolkata"

  // Weather snapshot cached to avoid re-fetching on regen
  weatherTempC        Float
  weatherFeelsLikeC   Float?
  weatherCondition    String
  weatherHumidityPct  Int?
  weatherWindKph      Float?
  weatherLocation     String  // city name

  // 3 curated outfit slots (stored as JSONB)
  // Each slot: { outfit_ids: string[], rationale, styling_tip, occasion_tags, vibe }
  // Nullable: becomes null when the user dismisses that slot for the day
  slot1           Json?
  slot2           Json?
  slot3           Json?

  // Regeneration tracking
  regenCount      Int       @default(0)
  regenSlot       Int?      // last regenerated slot: 1 | 2 | 3
  regenAt         DateTime?

  // Pipeline audit
  pipelineVersion  String?
  modelUsed        String?
  queryTierUsed    Int?      // 1 = weather-filtered, 2 = top 10 fallback
  totalCandidates  Int?
  latencyMs        Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, localDate, userTimezone])
  @@index([userId, localDate])
}

// ── USER STYLE PROFILE ─────────────────────────────────────────
// One row per user — stores Claude's running analysis of their style preferences.
// Updated automatically after every 5 curation interactions.
model UserStyleProfile {
  id     BigInt @id
  userId BigInt @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // User-provided preferences (from onboarding + feedback)
  preferredAesthetics  String[] @default([]) // e.g. ["minimal", "editorial"]
  avoidCombinations    String[] @default([]) // e.g. ["all black", "heavy layering"]
  favoriteColors       String[] @default([]) // e.g. ["cream", "brown", "slate blue"]
  occasions            String[] @default([]) // e.g. ["work", "events", "casual"]
  fitPreference        String?              // e.g. "fitted tops, wide leg bottoms"

  // AI-computed fields (updated by background analysis)
  leastWornCategories  String[] @default([]) // auto-computed from wear counts
  styleInsights        String?              // Claude's summary paragraph
  dominantPalette      String[] @default([]) // top colours across wardrobe
  interactionCount     Int      @default(0) // total curations delivered to this user
  lastAnalyzedAt       DateTime?            // when Claude last ran a full analysis

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ── OUTFIT HISTORY ─────────────────────────────────────────────
// Records every outfit Claude curated, for memory and variety enforcement.
model OutfitHistory {
  id     BigInt @id
  userId BigInt
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Outfit contents
  outfitName   String?  // e.g. "Slot 1 – Morning Look"
  itemIds      String[] // wardrobe item IDs included in this outfit
  itemNames    String[] // human-readable names (denormalised for prompt injection)
  stylingNote  String?  // Claude's rationale / styling tip
  vibe         String?  // e.g. "Relaxed", "Polished"
  occasionTags String[] @default([])

  // Outcome tracking
  wasWorn       Boolean? // null = unknown, true = user confirmed worn
  userFeedback  String?  // optional free-text: "loved it", "too casual" etc
  userRating    Int?     // 1–5

  // Source tracking
  curationId   BigInt?  // links back to DailyCuration
  slotNumber   Int?     // 1 | 2 | 3

  curatedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, curatedAt])
}

// ── SAVED OUTFITS ──────────────────────────────────────────────
// User-saved looks from the Today page curation.
model SavedOutfit {
  id     BigInt @id
  userId BigInt
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  outfitName   String
  lookType     String?   // MORNING | DAYTIME | EVENING
  mood         String?
  formality    String?
  items        Json      @default("[]")
  stylingNote  String?
  occasionTags String[]  @default([])
  tip          String?

  savedAt DateTime @default(now())

  @@index([userId])
  @@index([userId, savedAt])
}

// ── PASSWORD RESET TOKENS ─────────────────────────────────────
// Short-lived tokens for the "Forgot Password" flow.
// Token is a random 64-char hex string stored hashed (SHA-256).
model PasswordResetToken {
  id        BigInt   @id
  userId    BigInt
  tokenHash String   @unique // SHA-256 of the raw token so plaintext never persists
  expiresAt DateTime
  usedAt    DateTime?         // set when consumed; subsequent uses rejected
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ── USER STREAKS ──────────────────────────────────────────────
// Tracks consecutive daily visit streaks per user.
model UserStreak {
  userId         BigInt    @id
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime? @db.Date
  seenMilestones Json      @default("[]") // array of milestone numbers already celebrated
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("UserStreak")
}

// ── EMAIL LOGS ────────────────────────────────────────────────
// Records every marketing email sent so we never double-send
// and can track open/click rates via Resend webhooks later.
model EmailLog {
  id         BigInt   @id
  userId     BigInt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailType  String   // "daily_engagement" | "re_engagement" | "milestone"
  subject    String
  sentAt     DateTime @default(now())
  resendId   String?  // Resend's message ID for tracking
  localDate  String   // "YYYY-MM-DD" — deduplicate: one email per type per day per user

  @@unique([userId, emailType, localDate])
  @@index([userId, sentAt])
}
